# 数据库连接（生产必须修改）
# SQLite: sqlite:///./material_mgmt.db
# MySQL:  mysql+pymysql://user:pass@host:3306/dbname?charset=utf8mb4
DATABASE_URL=mysql+pymysql://root:MaterialMgmt2026!@localhost:3306/material_mgmt?charset=utf8mb4

# JWT 密钥（生产务必修改为随机字符串）
# 生成方式：openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# 数据库 root 密码（仅 Docker 部署用）
DB_ROOT_PASSWORD=MaterialMgmt2026!
